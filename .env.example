SENA_API_HOST=0.0.0.0
SENA_API_PORT=8000
SENA_POLICY_DIR=src/sena/examples/policies
SENA_BUNDLE_NAME=enterprise-compliance-controls
SENA_BUNDLE_VERSION=2026.03
SENA_LOG_LEVEL=INFO
SENA_API_KEY_ENABLED=false
# SENA_API_KEY=
# SENA_AUDIT_SINK_JSONL=

# Optional policy store backend config for API container
SENA_POLICY_STORE_BACKEND=filesystem
SENA_POLICY_STORE_SQLITE_PATH=/data/policy_registry.db

# Optional DB profile (docker compose --profile db)
SENA_DB_NAME=sena
SENA_DB_USER=sena
SENA_DB_PASSWORD=sena_dev_password
SENA_DB_PORT=5432
